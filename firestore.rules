rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Document ID: 6-character room key
    // Fields:
    //   - name: string (required)
    //   - ownerId: string (required, immutable)
    //   - videoState: map (required)
    //     - currentTime: number
    //     - isPlaying: boolean
    //     - lastUpdated: timestamp
    //     - videoUrl: string
    //   - users: map (required)
    //
    // Collection: rooms/{roomId}/messages
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 500 chars)
    //   - senderId: string (required, immutable)
    //   - senderName: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(roomId) {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isSender() {
      return isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'ownerId', 'videoState', 'users']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId == request.auth.uid &&
             data.videoState is map &&
             data.users is map;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.timestamp is timestamp;
    }

    // Room rules
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && 
                    (isOwner(roomId) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['users']) && 
                      request.resource.data.users.keys().hasAll(resource.data.users.keys())));
      allow delete: if isOwner(roomId);

      // Message rules
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
        allow update, delete: if isSender();
      }
    }
  }
}
